{
  "name": "R Bioconductor Dev (Codespaces)",
  "image": "ghcr.io/cruk-mi/mesa/devcontainer:codespaces-slim",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "REditorSupport.r",
        "ikuyadeu.r",
        "ms-python.python"
      ],
      "settings": {
        "r.rterm.linux": "/usr/local/bin/R",
        "r.lsp.path": "/usr/local/bin/R",
        "r.alwaysUseActiveTerminal": true,
        "r.bracketedPaste": true,
        "r.plot.devArgs": { "width": 1200, "height": 500 }
      }
    }
  },
  "containerEnv": {
    "R_REMOTES_NO_ERRORS_FROM_WARNINGS": "true"
  },
  "postCreateCommand": "R -e \"remotes::install_local('.', upgrade = 'never', dependencies = FALSE)\""
}
