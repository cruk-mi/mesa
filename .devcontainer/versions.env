# Optional version overrides for the devcontainer / CI toolchain.
#
# You normally DO NOT edit this file. The R version comes from the
# `R (>= X.Y.Z)` line in DESCRIPTION, and the Bioconductor version is
# derived from it automatically (latest released Bioc for that R) by
# .devcontainer/resolve_versions.sh.
#
# Uncomment a line below ONLY to override the automatic resolution:
#
#   BIOC_VERSION=3.23   # pin a specific Bioc release within an R series
#                       # (e.g. stay on 3.23 after 3.24 is released)
#   R_VERSION=4.6       # override the R version parsed from DESCRIPTION
#                       # (almost never needed — bump DESCRIPTION instead)
