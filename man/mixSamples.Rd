data(exampleTumourNormal, package = "mesa")


# Mix two samples 50/50 into ~100k total fragments; append to the qseaSet
exampleTumourNormal \%>\% 
  mixSamples("Colon1_T", 
             "Colon1_N", 
             nReadsTotal = 100000, 
             proportion = 0.5, 
